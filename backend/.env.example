# ── Banco de dados SQL Server ─────────────────────────────────────────────────
DB_SERVER=localhost
DB_USER=sa
DB_PASSWORD=change-me
DB_NAME=Protheus_Producao
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_CLIENT=pymssql
BI_DB_NAME=BISOBEL

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-with-a-random-secret-key
